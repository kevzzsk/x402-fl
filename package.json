{
  "name": "x402-fl",
  "version": "0.0.0",
  "description": "Local x402 payment facilitator for development and testing. Fork Base mainnet with Anvil, verify and settle x402 payments locally.",
  "type": "module",
  "bin": {
    "x402-fl": "dist/cli.js"
  },
  "exports": {
    "./testcontainers": {
      "import": "./dist/testcontainers.js",
      "types": "./dist/testcontainers.d.ts"
    }
  },
  "files": [
    "dist",
    "Dockerfile",
    "pnpm-lock.yaml"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsx src/cli.ts dev",
    "pretest": "pnpm build",
    "test": "vitest run"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kevzzsk/x402-fl.git"
  },
  "homepage": "https://github.com/kevzzsk/x402-fl#readme",
  "bugs": {
    "url": "https://github.com/kevzzsk/x402-fl/issues"
  },
  "author": "kevzzsk",
  "keywords": [
    "x402",
    "facilitator",
    "local",
    "development",
    "anvil"
  ],
  "license": "MIT",
  "dependencies": {
    "@x402/core": "^2.5.0",
    "@x402/evm": "^2.5.0",
    "boxen": "^8.0.1",
    "chalk": "^5.6.2",
    "commander": "^12.1.0",
    "express": "^4.21.2",
    "viem": "^2.39.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^24.0.0",
    "testcontainers": "^11.12.0",
    "tsdown": "0.21.0-beta.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "testcontainers": "^11.0.0"
  },
  "peerDependenciesMeta": {
    "testcontainers": {
      "optional": true
    }
  },
  "packageManager": "pnpm@10.28.2",
  "engines": {
    "node": ">=24"
  }
}
